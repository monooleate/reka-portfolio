---
import Icon from './Icon.astro';
import { t, type Lang } from '../lib/i18n';

interface Props {
	lang: Lang;
	/** Visual style: solid gradient (default) or subtle outline. */
	variant?: 'solid' | 'outline';
	/** Compact = icon-only on mobile, icon + label on desktop (for the header). */
	compact?: boolean;
}

const { lang, variant = 'solid', compact = false } = Astro.props;
const cvHref = '/Reka_Meszaros_Erdei_CV_EU.pdf';
---

<a
	class:list={['cv-download', variant, { compact }]}
	href={cvHref}
	download
	aria-label={t(lang, 'cv.aria')}
>
	<Icon icon="download-simple" size="1.15em" />
	<span class="label">{t(lang, 'cv.download')}</span>
</a>

<style>
	.cv-download {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.6em;
		width: fit-content;
		padding: 0.7em 1.6em;
		border-radius: var(--radius-full);
		font-family: var(--font-brand);
		font-weight: 600;
		font-size: var(--text-md);
		line-height: 1.1;
		letter-spacing: 0.01em;
		text-decoration: none;
		white-space: nowrap;
		transition:
			transform var(--hover-transition),
			box-shadow var(--hover-transition),
			background-color var(--hover-transition),
			border-color var(--hover-transition);
	}

	.cv-download.solid {
		color: var(--accent-text-over);
		background: var(--gradient-accent-orange);
		/* Accent glow so the button stands out against the header/hero. */
		box-shadow: 0 4px 16px -2px hsla(280, 65%, 50%, 0.5), var(--shadow-sm);
	}

	.cv-download.outline {
		color: var(--accent-regular);
		background: var(--gray-999);
		border: 1px solid var(--accent-regular);
		box-shadow: var(--shadow-sm);
	}

	.cv-download:hover {
		transform: translateY(-2px);
	}

	.cv-download.solid:hover {
		box-shadow: 0 7px 22px -2px hsla(280, 65%, 50%, 0.65), var(--shadow-md);
	}

	.cv-download.outline:hover {
		background: var(--accent-subtle-overlay);
		box-shadow: var(--shadow-md);
	}

	.cv-download:active {
		transform: translateY(0);
	}

	.cv-download:focus-visible {
		outline: 2px solid var(--accent-regular);
		outline-offset: 3px;
	}

	/* Compact: icon-only on small screens, full label from 50em up. */
	.cv-download.compact {
		padding: 0.5em 0.8em;
		font-size: var(--text-base);
	}

	.cv-download.compact .label {
		display: none;
	}

	@media (min-width: 50em) {
		.cv-download.compact {
			padding: 0.6em 1.3em;
		}

		.cv-download.compact .label {
			display: inline;
		}
	}
</style>
