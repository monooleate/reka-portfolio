---
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';
import { t, type Lang } from "../lib/i18n";
import type { iconPaths } from './IconPaths';
import LanguageToggle from "./LanguageToggle.astro";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Nyelvspecifikus útvonalak:
const routes = {
  hu: {
    home: "/hu/",
    work: "/hu/munkaim/",
    about: "/hu/rolam/",
  },
  en: {
    home: "/en/",
    work: "/en/work/",
    about: "/en/about/",
  }
} as const;

const textLinks = [
  { label: "nav.home", href: routes[lang].home },
  { label: "nav.work", href: routes[lang].work },
  { label: "nav.about", href: routes[lang].about },
];

const iconLinks: { label: string; href: string; icon: keyof typeof iconPaths }[] = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/reka-meszaros-erdei-696769a6/', icon: 'linkedin-logo' },
];

const isCurrentPage = (href: string) => {
  let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
  if (pathname.at(0) !== '/') pathname = '/' + pathname;
  if (pathname.at(-1) !== '/') pathname += '/';
  return pathname === href || (href !== `/${lang}/` && pathname.startsWith(href));
};

const slugMap = {
  hu: {
    "/munkaim/": "/work/",
    "/rolam/": "/about/",
    "/": "/"
  },
  en: {
    "/work/": "/munkaim/",
    "/about/": "/rolam/",
    "/": "/"
  }
} as const;

// Language switch
const otherLang = lang === "hu" ? "en" : "hu";
let path = Astro.url.pathname.replace(/^\/(hu|en)/, "") || "/";
if (!path.endsWith("/")) path += "/";
const translatedSlug = slugMap[lang][path] ?? "/";
const switchHref = `/${otherLang}${translatedSlug}`;
---

<nav>
	<div class="menu-header">
		<a href={`/${lang}/`} class="site-title">
			<Icon icon="terminal-window" color="var(--accent-regular)" size="1.6em" gradient />
			{t(lang, "site.title")}
		</a>

		<menu-button>
			<template>
				<button class="menu-button" aria-expanded="false">
					<span class="sr-only">Menu</span>
					<Icon icon="list" />
				</button>
			</template>
		</menu-button>
	</div>

	<div id="menu-content" hidden>
		<ul class="nav-items">
			{ textLinks.map(({ label, href }) => (
				<li>
					<a aria-current={isCurrentPage(href) ? 'page' : null} class="link" href={href}>
						{t(lang, label)}
					</a>
				</li>
			)) }
		</ul>

		<div class="menu-footer">

			<!-- Nyelvváltó -->
			<LanguageToggle lang={lang} href={switchHref} />

			<!-- Theme toggle -->
			<div class="theme-toggle">
				<ThemeToggle />
			</div>

			<div class="socials">
				{ iconLinks.map(({ href, icon, label }) => (
					<a href={href} class="social" target="_blank" rel="noopener noreferrer">
						<span class="sr-only">{label}</span>
						<Icon icon={icon} />
					</a>
				)) }
			</div>
		</div>
	</div>
</nav>

<script>
	class MenuButton extends HTMLElement {
		constructor() {
			super();

			// Inject menu toggle button when JS runs.
			this.appendChild(this.querySelector('template')!.content.cloneNode(true));
			const btn = this.querySelector('button')!;

			// Hide menu (shown by default to support no-JS browsers).
			const menu = document.getElementById('menu-content')!;
			menu.hidden = true;
			// Add "menu-content" class in JS to avoid covering content in non-JS browsers.
			menu.classList.add('menu-content');

			/** Set whether the menu is currently expanded or collapsed. */
			const setExpanded = (expand: boolean) => {
				btn.setAttribute('aria-expanded', expand ? 'true' : 'false');
				menu.hidden = !expand;
			};

			// Toggle menu visibility when the menu button is clicked.
			btn.addEventListener('click', () => setExpanded(menu.hidden));

			// Hide menu button for large screens.
			const handleViewports = (e: MediaQueryList | MediaQueryListEvent) => {
				setExpanded(e.matches);
				btn.hidden = e.matches;
			};
			const mediaQueries = window.matchMedia('(min-width: 50em)');
			handleViewports(mediaQueries);
			mediaQueries.addEventListener('change', handleViewports);
		}
	}
	customElements.define('menu-button', MenuButton);

	// Add scrolled class on scroll
	const nav = document.querySelector('nav');
	const handleScroll = () => {
		if (window.scrollY > 20) {
			nav?.classList.add('scrolled');
		} else {
			nav?.classList.remove('scrolled');
		}
	};
	window.addEventListener('scroll', handleScroll, { passive: true });
	handleScroll(); // Initial check
</script>

<style>
	nav {
		z-index: 9999;
		position: sticky;
		top: 0;
		font-family: var(--font-brand);
		font-weight: 500;
		margin-bottom: 1.5rem;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		background: rgba(var(--gray-999-basis), 0.9);
		border-bottom: 1px solid var(--gray-800);
		transition: box-shadow var(--hover-transition), border-color var(--hover-transition);
	}

	nav.scrolled {
		box-shadow: var(--shadow-sm);
		border-bottom-color: var(--accent-subtle-overlay);
	}

	.menu-header {
		display: flex;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 1.5rem;
	}

	.site-title {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		line-height: 1.1;
		color: var(--gray-0);
		text-decoration: none;
	}

	.menu-button {
		position: relative;
		display: flex;
		border: 0;
		border-radius: var(--radius-full);
		padding: 0.5rem;
		font-size: 1.5rem;
		color: var(--gray-0);
		background: var(--accent-regular);
		box-shadow: var(--shadow-sm);
		cursor: pointer;
		transition: transform var(--hover-transition), background var(--hover-transition);
	}

	.menu-button:hover {
		transform: scale(1.05);
		background: var(--accent-dark);
	}

	.menu-button[aria-expanded='true'] {
		color: var(--accent-text-over);
		background: var(--accent-dark);
	}

	.menu-button[hidden] {
		display: none;
	}

	.menu-button::before {
		display: none;
	}

	.menu-content {
		position: absolute;
		left: 0;
		right: 0;
	}

	.nav-items {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		font-size: var(--text-md);
		line-height: 1.2;
		list-style: none;
		padding: 2rem;
		background-color: var(--gray-999);
		border-bottom: 1px solid var(--gray-800);
	}

	.link {
		display: inline-block;
		color: var(--gray-400);
		text-decoration: none;
		transition: color var(--hover-transition);
	}

	.link:hover {
		color: var(--gray-0);
	}

	.link[aria-current] {
		color: var(--gray-0);
		font-weight: 600;
	}

	.menu-footer {
		--icon-size: var(--text-xl);
		--icon-padding: 0.5rem;

		display: flex;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 1.5rem 2rem 1.5rem 1.5rem;
		background-color: var(--gray-999);
		border-radius: 0 0 var(--radius-md) var(--radius-md);
		box-shadow: var(--shadow-md);
	}

	.socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.625rem;
		font-size: var(--icon-size);
	}

	.social {
		display: flex;
		padding: var(--icon-padding);
		text-decoration: none;
		color: var(--gray-400);
		transition: color var(--hover-transition), transform var(--hover-transition);
	}

	.social:hover,
	.social:focus {
		color: var(--accent-regular);
		transform: scale(1.1);
	}

	.theme-toggle {
		display: flex;
		align-items: center;
		height: calc(var(--icon-size) + 2 * var(--icon-padding));
	}

	@media (min-width: 50em) {
		nav {
			display: grid;
			grid-template-columns: 1fr auto 1fr;
			align-items: center;
			padding: 1.25rem 5rem;
			gap: 1rem;
		}

		.menu-header {
			padding: 0;
		}

		.site-title {
			font-size: var(--text-lg);
		}

		.menu-content {
			display: contents;
		}

		.nav-items {
			position: relative;
			flex-direction: row;
			font-size: var(--text-sm);
			border-radius: var(--radius-full);
			border: 1px solid var(--gray-800);
			padding: 0.5rem 0.5625rem;
			background: var(--gray-999);
			box-shadow: var(--shadow-sm);
		}

		.nav-items::before {
			display: none;
		}

		.link {
			padding: 0.5rem 1rem;
			border-radius: var(--radius-full);
			color: var(--gray-300);
			transition:
				color var(--hover-transition),
				background-color var(--hover-transition);
		}

		.link:hover,
		.link:focus {
			color: var(--gray-0);
			background-color: var(--accent-subtle-overlay);
		}

		.link[aria-current='page'] {
			color: var(--accent-text-over);
			background-color: var(--accent-regular);
			font-weight: 500;
		}

		.menu-footer {
			--icon-padding: 0.375rem;

			justify-self: flex-end;
			align-items: center;
			padding: 0;
			background-color: transparent;
			box-shadow: none;
		}

		.socials {
			display: none;
		}
	}

	@media (min-width: 60em) {
		.socials {
			display: flex;
			justify-content: flex-end;
			gap: 0;
		}
	}
	@media (forced-colors: active) {
		.link[aria-current='page'] {
			color: SelectedItem;
		}
	}
</style>
