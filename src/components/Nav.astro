---
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';
import CvDownload from './CvDownload.astro';
import LanguageToggle from './LanguageToggle.astro';
import { t, type Lang } from "../lib/i18n";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Single landing page per language — the language switch just flips the locale root.
const otherLang = lang === "hu" ? "en" : "hu";
const switchHref = `/${otherLang}/`;

const linkedinHref = "https://www.linkedin.com/in/reka-meszaros-erdei-696769a6/";
---

<nav>
	<a href={`/${lang}/`} class="site-title">
		<Icon icon="terminal-window" color="var(--accent-regular)" size="1.6em" gradient />
		<span>{t(lang, "hero.name")}</span>
	</a>

	<div class="actions">
		<LanguageToggle lang={lang} href={switchHref} />

		<div class="theme-toggle">
			<ThemeToggle />
		</div>

		<a href={linkedinHref} class="social" target="_blank" rel="noopener noreferrer">
			<span class="sr-only">LinkedIn</span>
			<Icon icon="linkedin-logo" />
		</a>

		<CvDownload lang={lang} compact />
	</div>
</nav>

<script>
	// Add a subtle shadow once the page is scrolled.
	const nav = document.querySelector('nav');
	const handleScroll = () => {
		if (window.scrollY > 20) nav?.classList.add('scrolled');
		else nav?.classList.remove('scrolled');
	};
	window.addEventListener('scroll', handleScroll, { passive: true });
	handleScroll();
</script>

<style>
	nav {
		z-index: 9999;
		position: sticky;
		top: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem 1rem;
		padding: 1rem 1.5rem;
		font-family: var(--font-brand);
		font-weight: 500;
		margin-bottom: 1.5rem;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		background: rgba(var(--gray-999-basis), 0.9);
		border-bottom: 1px solid var(--gray-800);
		transition: box-shadow var(--hover-transition), border-color var(--hover-transition);
	}

	nav.scrolled {
		box-shadow: var(--shadow-sm);
		border-bottom-color: var(--accent-subtle-overlay);
	}

	.site-title {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		line-height: 1.1;
		color: var(--gray-0);
		text-decoration: none;
		font-size: var(--text-md);
	}

	.actions {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		margin-left: auto;
	}

	.theme-toggle {
		display: flex;
		align-items: center;
	}

	.social {
		display: flex;
		padding: 0.4rem;
		font-size: var(--text-xl);
		color: var(--gray-400);
		text-decoration: none;
		transition: color var(--hover-transition), transform var(--hover-transition);
	}

	.social:hover,
	.social:focus {
		color: var(--accent-regular);
		transform: scale(1.1);
	}

	@media (min-width: 50em) {
		nav {
			flex-wrap: nowrap;
			padding: 1.25rem 2.5rem;
		}

		.site-title {
			font-size: var(--text-lg);
		}

		.actions {
			gap: 0.75rem;
		}
	}

	@media (forced-colors: active) {
		.social {
			color: LinkText;
		}
	}
</style>
