---
import CallToAction from './CallToAction.astro';
import Icon from './Icon.astro';
import { t, type Lang } from "../lib/i18n";

export interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
---

<aside>
	<h2>{t(lang, "contact.title")}</h2>
	<p class="subtitle">{t(lang, "contact.subtitle")}</p>
	<CallToAction href="mailto:erdeireka87@gmail.com">
		{t(lang, "contact.email")}
		<Icon icon="paper-plane-tilt" size="1.2em" />
	</CallToAction>
</aside>

<style>
	aside {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.75rem;
		border-top: 1px solid var(--gray-800);
		border-bottom: 1px solid var(--gray-800);
		padding: 5rem 1.5rem;
		background: linear-gradient(180deg, transparent 0%, var(--accent-overlay) 50%, transparent 100%);
		text-align: center;
	}

	h2 {
		font-size: var(--text-xl);
		font-weight: 500;
		max-width: 20ch;
		margin: 0;
	}

	.subtitle {
		font-size: var(--text-md);
		color: var(--gray-400);
		max-width: 40ch;
		margin: 0;
		line-height: 1.6;
	}

	@media (min-width: 50em) {
		aside {
			padding: 7.5rem;
			gap: 2rem;
		}

		h2 {
			font-size: var(--text-3xl);
		}

		.subtitle {
			font-size: var(--text-lg);
		}
	}
</style>
