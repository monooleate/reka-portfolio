---
// Self-hosted fonts (no render-blocking third-party requests).
import '../styles/fonts.css';
import '../styles/global.css';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
	lang?: string;
	canonicalUrl?: string;
	/** Absolute or root-relative path of the LCP image to preload (homepage hero). */
	heroImage?: string;
}

const {
	title = "Réka Mészáros-Erdei | IT Business Consultant",
	description = "IT Business Consultant and Digital Transformation Specialist with expertise in IT strategy, process optimization, and product ownership.",
	lang = "en",
	canonicalUrl,
	heroImage,
} = Astro.props;

const siteUrl = Astro.site?.href || "https://rekaerdei.com";
const pageUrl = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Réka Mészáros-Erdei",
	"alternateName": "Mészáros-Erdei Réka",
	"jobTitle": "IT Business Consultant",
	"url": siteUrl,
	"sameAs": ["https://www.linkedin.com/in/reka-meszaros-erdei-696769a6/"],
	"email": "erdeireka87@gmail.com",
	"address": {
		"@type": "PostalAddress",
		"addressLocality": "Diósd",
		"addressCountry": "HU"
	},
	"knowsLanguage": ["hu", "en", "de"],
	"alumniOf": {
		"@type": "CollegeOrUniversity",
		"name": "Budapest University of Technology and Economics"
	},
	"hasCredential": [
		{
			"@type": "EducationalOccupationalCredential",
			"credentialCategory": "degree",
			"name": "MSc in Chemical Engineering"
		},
		{
			"@type": "EducationalOccupationalCredential",
			"credentialCategory": "degree",
			"name": "BSc in Chemical and Process Engineering"
		}
	],
	"knowsAbout": [
		"Business Analysis",
		"Digital Transformation",
		"IT Strategy",
		"Agile Methodology",
		"Process Optimization",
		"Requirement Gathering",
		"Stakeholder Management"
	],
	"worksFor": {
		"@type": "Organization",
		"name": "CommIT Smart"
	}
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Réka Mészáros-Erdei Portfolio",
	"url": siteUrl,
	"inLanguage": ["hu", "en"],
	"author": {
		"@type": "Person",
		"name": "Réka Mészáros-Erdei"
	}
};
---

<meta charset="UTF-8" />
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content="Réka Mészáros-Erdei" />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#7611a6" />

<!-- Open Graph / Social -->
<meta property="og:type" content="website" />
<meta property="og:url" content={pageUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:locale" content={lang === "hu" ? "hu_HU" : "en_US"} />
<meta property="og:locale:alternate" content={lang === "hu" ? "en_US" : "hu_HU"} />
<meta property="og:site_name" content="Réka Mészáros-Erdei" />
<meta property="og:image" content={new URL("og-image.jpg", siteUrl).href} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Réka Mészáros-Erdei — Business Analyst" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL("og-image.jpg", siteUrl).href} />

<!-- Canonical URL -->
<link rel="canonical" href={pageUrl} />

<!-- Alternate language versions -->
<link rel="alternate" hreflang="en" href={`${siteUrl}en/`} />
<link rel="alternate" hreflang="hu" href={`${siteUrl}hu/`} />
<link rel="alternate" hreflang="x-default" href={`${siteUrl}en/`} />

<title>{title}</title>

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Preload critical fonts so hero text paints with the brand font near FCP (better LCP) -->
<link rel="preload" as="font" type="font/woff2" href="/fonts/public-sans-latin-400-normal.woff2" crossorigin />
<link rel="preload" as="font" type="font/woff2" href="/fonts/rubik-latin-500-normal.woff2" crossorigin />
{lang === "hu" && <link rel="preload" as="font" type="font/woff2" href="/fonts/public-sans-latin-ext-400-normal.woff2" crossorigin />}

<!-- Preload the hero (LCP) image on pages that have one (responsive: small on mobile, larger on desktop) -->
{heroImage && (
	<>
		<link rel="preload" as="image" type="image/webp" href={`${heroImage}-400.webp`} media="(max-width: 49.999em)" fetchpriority="high" />
		<link rel="preload" as="image" type="image/webp" href={`${heroImage}-600.webp`} media="(min-width: 50em)" fetchpriority="high" />
	</>
)}

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

<script is:inline>
	// This code is inlined in the head to make dark mode instant & blocking.
	const getThemePreference = () => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	};
	const isDark = getThemePreference() === 'dark';
	document.documentElement.classList[isDark ? 'add' : 'remove']('theme-dark');

	if (typeof localStorage !== 'undefined') {
		// Watch the document element and persist user preference when it changes.
		const observer = new MutationObserver(() => {
			const isDark = document.documentElement.classList.contains('theme-dark');
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
		});
		observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
	}
</script>
