---
import { getCollection } from 'astro:content';
import ContactCTA from '../../components/ContactCTA.astro';
import Grid from '../../components/Grid.astro';
import Hero from '../../components/Hero.astro';
import PortfolioPreview from '../../components/PortfolioPreview.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from "../../lib/i18n";

const lang = "en";

const projects = (await getCollection('work', ({ id }) => id.startsWith('en/'))).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title={`${t(lang, "work.title")} | ${t(lang, "site.title")}`}
	description={t(lang, "site.description")}
	lang={lang}
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title={t(lang, "work.title")}
				tagline={t(lang, "work.subtitle")}
				align="start"
			/>
			<Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} lang={lang} />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA lang={lang} />
	</div>
</BaseLayout>
