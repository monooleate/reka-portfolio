---
import ContactCTA from '../../components/ContactCTA.astro';
import CvDownload from '../../components/CvDownload.astro';
import Hero from '../../components/Hero.astro';
import WorkExperience from '../../components/WorkExperience.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from "../../lib/i18n";

const lang = "en";
---

<BaseLayout
	title={`${t(lang, "work.exp.title")} | ${t(lang, "site.title")}`}
	description={t(lang, "work.exp.subtitle")}
	lang={lang}
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-15 lg:gap-20">
			<Hero
				title={t(lang, "work.exp.title")}
				tagline={t(lang, "work.exp.subtitle")}
				align="start"
			>
				<div class="hero-actions">
					<CvDownload lang={lang} />
				</div>
			</Hero>

			<WorkExperience lang={lang} />
		</main>
		<ContactCTA lang={lang} />
	</div>
</BaseLayout>

<style>
	.hero-actions {
		display: flex;
		justify-content: center;
		margin-top: 0.5rem;
	}

	@media (min-width: 50em) {
		.hero-actions {
			justify-content: flex-start;
		}
	}
</style>
