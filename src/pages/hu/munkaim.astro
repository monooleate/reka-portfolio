---
import { getCollection } from 'astro:content';
import CareerHighlights from '../../components/CareerHighlights.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import CvDownload from '../../components/CvDownload.astro';
import Grid from '../../components/Grid.astro';
import Hero from '../../components/Hero.astro';
import PortfolioPreview from '../../components/PortfolioPreview.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from "../../lib/i18n";

const lang = "hu";

const projects = (await getCollection('work', ({ id }) => id.startsWith('hu/'))).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title={`${t(lang, "work.title")} | ${t(lang, "site.title")}`}
	description={t(lang, "work.subtitle")}
	lang={lang}
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-15 lg:gap-20">
			<Hero
				title={t(lang, "work.title")}
				tagline={t(lang, "work.subtitle")}
				align="start"
			>
				<div class="hero-actions">
					<CvDownload lang={lang} />
				</div>
			</Hero>

			<CareerHighlights lang={lang} />

			<Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} lang={lang} />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA lang={lang} />
	</div>
</BaseLayout>

<style>
	.hero-actions {
		display: flex;
		justify-content: center;
		margin-top: 0.5rem;
	}

	@media (min-width: 50em) {
		.hero-actions {
			justify-content: flex-start;
		}
	}
</style>
