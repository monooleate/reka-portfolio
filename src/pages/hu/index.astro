---
import AboutMe from '../../components/AboutMe.astro';
import CareerPath from '../../components/CareerPath.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Education from '../../components/Education.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';
import Skills from '../../components/Skills.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from "../../lib/i18n";

const lang = "hu";
---

<BaseLayout
	title={t(lang, "site.title")}
	description={t(lang, "site.description")}
	lang={lang}
	heroImage="/assets/portrait"
>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title={t(lang, "heroTitle")}
					tagline={t(lang, "heroSubtitle")}
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="clipboard-text" size="1.33em" /> {t(lang, "hero.role.analyst")}</Pill>
						<Pill><Icon icon="lightning" size="1.33em" /> {t(lang, "hero.role.digital")}</Pill>
						<Pill><Icon icon="kanban" size="1.33em" /> {t(lang, "hero.role.process")}</Pill>
					</div>
				</Hero>

				<picture>
					<source media="(min-width: 50em)" type="image/webp" srcset="/assets/portrait-600.webp" />
					<source type="image/webp" srcset="/assets/portrait-400.webp" />
					<img
						alt="Mészáros-Erdei Réka - IT üzleti tanácsadó"
						width="480"
						height="620"
						src="/assets/portrait.jpg"
						fetchpriority="high"
						loading="eager"
						decoding="async"
					/>
				</picture>
			</header>

			<Skills lang={lang} />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<CareerPath lang={lang} />

			<Education lang={lang} />

			<AboutMe lang={lang} />
		</main>

		<ContactCTA lang={lang} />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero picture {
		display: contents;
	}

	.hero source {
		display: none;
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}
</style>
