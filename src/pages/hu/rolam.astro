---
import ContactCTA from '../../components/ContactCTA.astro';
import Education from '../../components/Education.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from "../../lib/i18n";

const lang = "hu";

const hobbies = [
  { key: 'winter', icon: 'snowflake' as const },
  { key: 'climb', icon: 'mountains' as const },
  { key: 'board', icon: 'skateboard' as const },
  { key: 'fitness', icon: 'barbell' as const },
];
---

<BaseLayout
	title={`${t(lang, "about.title")} | ${t(lang, "site.title")}`}
	description={t(lang, "site.description")}
	lang={lang}
>
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title={t(lang, "about.title")}
				tagline={t(lang, "about.tagline")}
			>
				<img
					width="600"
					style="display:block; margin:0 auto;"
					src="/assets/portrait.jpg"
					alt="Professional picture about Réka Mészáros-Erdei"
				/>
			</Hero>

			<!-- Intro Section -->
			<section class="intro-section">
				<div class="intro-card">
					<div class="intro-icon">
						<Icon icon="sparkle" color="var(--accent-regular)" size="2rem" gradient />
					</div>
					<h2>{t(lang, "about.intro.title")}</h2>
					<p>{t(lang, "about.intro.text")}</p>
				</div>
			</section>

			<!-- Personal Section -->
			<section class="personal-section">
				<div class="section-header-centered">
					<Icon icon="heart" color="var(--accent-regular)" size="1.5rem" gradient />
					<h2>{t(lang, "about.personal.title")}</h2>
				</div>
				<p class="personal-intro">{t(lang, "about.personal.intro")}</p>

				<!-- Hobbies Grid -->
				<div class="hobbies-grid">
					{hobbies.map((hobby) => (
						<div class="hobby-card">
							<div class="hobby-icon">
								<Icon icon={hobby.icon} color="var(--accent-regular)" size="2rem" gradient />
							</div>
							<h3>{t(lang, `about.hobbies.${hobby.key}`)}</h3>
							<p>{t(lang, `about.hobbies.${hobby.key}.desc`)}</p>
						</div>
					))}
				</div>
			</section>

			<!-- Travel Section -->
			<section class="travel-section">
				<div class="travel-content">
					<div class="travel-icon">
						<Icon icon="airplane-tilt" color="var(--accent-regular)" size="2.5rem" gradient />
					</div>
					<div class="travel-text">
						<h2>{t(lang, "about.travel.title")}</h2>
						<p>{t(lang, "about.travel.text")}</p>
						<div class="language-badges">
							<span class="lang-badge">🇭🇺 Magyar</span>
							<span class="lang-badge">🇬🇧 English</span>
							<span class="lang-badge">🇩🇪 Deutsch</span>
							<span class="lang-badge">🇪🇸 Español</span>
						</div>
					</div>
				</div>
			</section>

			<!-- Values Section -->
			<section class="values-section">
				<div class="values-card">
					<Icon icon="compass" color="var(--accent-regular)" size="2rem" gradient />
					<h2>{t(lang, "about.values.title")}</h2>
					<p>{t(lang, "about.values.text")}</p>
				</div>
			</section>

			<!-- Education -->
			<section class="education-wrapper">
				<Education lang={lang} />
			</section>
		</main>

		<ContactCTA lang={lang} />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 4rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	/* Intro Section */
	.intro-section {
		display: flex;
		justify-content: center;
	}

	.intro-card {
		max-width: 700px;
		text-align: center;
		padding: 2.5rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: var(--radius-xl);
	}

	.intro-icon {
		margin-bottom: 1rem;
	}

	.intro-card h2 {
		font-size: var(--text-2xl);
		font-weight: 500;
		color: var(--gray-0);
		margin: 0 0 1rem;
	}

	.intro-card p {
		font-size: var(--text-md);
		color: var(--gray-300);
		line-height: 1.8;
		margin: 0;
	}

	/* Personal Section */
	.personal-section {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.section-header-centered {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
	}

	.section-header-centered h2 {
		font-size: var(--text-2xl);
		font-weight: 500;
		color: var(--gray-0);
		margin: 0;
	}

	.personal-intro {
		text-align: center;
		font-size: var(--text-md);
		color: var(--gray-300);
		max-width: 700px;
		margin: 0 auto;
		line-height: 1.7;
	}

	/* Hobbies Grid */
	.hobbies-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		margin-top: 1rem;
	}

	.hobby-card {
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: var(--radius-lg);
		padding: 2rem;
		text-align: center;
		transition: transform var(--hover-transition), border-color var(--hover-transition), box-shadow var(--hover-transition);
	}

	.hobby-card:hover {
		transform: translateY(-3px);
		border-color: var(--accent-subtle-overlay);
		box-shadow: var(--shadow-sm);
	}

	.hobby-icon {
		margin-bottom: 1rem;
	}

	.hobby-card h3 {
		font-size: var(--text-lg);
		color: var(--gray-0);
		margin: 0 0 0.75rem;
	}

	.hobby-card p {
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin: 0;
		line-height: 1.6;
	}

	/* Travel Section */
	.travel-section {
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 2rem;
		padding: 2.5rem;
	}

	.travel-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
	}

	.travel-icon {
		padding: 1rem;
		background: var(--accent-overlay);
		border-radius: 50%;
	}

	.travel-text h2 {
		font-size: var(--text-xl);
		color: var(--gray-0);
		margin: 0 0 1rem;
	}

	.travel-text p {
		font-size: var(--text-md);
		color: var(--gray-300);
		line-height: 1.7;
		margin: 0 0 1.5rem;
	}

	.language-badges {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem;
	}

	.lang-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: 2rem;
		font-size: var(--text-sm);
		color: var(--gray-200);
		transition: border-color 0.2s ease, transform 0.2s ease;
	}

	.lang-badge:hover {
		border-color: var(--accent-regular);
		transform: scale(1.05);
	}

	/* Values Section */
	.values-section {
		display: flex;
		justify-content: center;
	}

	.values-card {
		max-width: 700px;
		text-align: center;
		padding: 2.5rem;
		background: linear-gradient(135deg, var(--accent-overlay) 0%, transparent 100%);
		border: 1px solid var(--accent-regular);
		border-radius: 2rem;
	}

	.values-card h2 {
		font-size: var(--text-xl);
		color: var(--gray-0);
		margin: 1rem 0;
	}

	.values-card p {
		font-size: var(--text-md);
		color: var(--gray-200);
		line-height: 1.7;
		margin: 0;
	}

	/* Education Wrapper */
	.education-wrapper {
		margin-top: 1rem;
	}

	@media (min-width: 50em) {
		.about {
			gap: 5rem;
		}

		.intro-card {
			padding: 3rem 4rem;
		}

		.intro-card h2 {
			font-size: var(--text-3xl);
		}

		.section-header-centered h2 {
			font-size: var(--text-3xl);
		}

		.hobbies-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 2rem;
		}

		.hobby-card {
			padding: 2.5rem;
		}

		.hobby-card h3 {
			font-size: var(--text-xl);
		}

		.hobby-card p {
			font-size: var(--text-base);
		}

		.travel-section {
			padding: 3rem 4rem;
		}

		.travel-content {
			flex-direction: row;
			text-align: left;
			gap: 2.5rem;
		}

		.travel-text {
			flex: 1;
		}

		.travel-text h2 {
			font-size: var(--text-2xl);
		}

		.language-badges {
			justify-content: flex-start;
		}

		.values-card {
			padding: 3rem 4rem;
		}

		.values-card h2 {
			font-size: var(--text-2xl);
		}
	}

	@media (min-width: 60em) {
		.hobbies-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}
</style>
